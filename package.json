{
  "name": "node-file-caching",
  "version": "2.0.0",
  "description": "Zero-dependency file caching for Node.js with TTL, namespaces, entry limits, and stats",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./index.d.mts",
        "default": "./index.mjs"
      },
      "require": {
        "types": "./index.d.ts",
        "default": "./index.js"
      }
    }
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "index.d.mts",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14.14.0"
  },
  "scripts": {
    "lint": "eslint index.js index.test.js",
    "test:cc": "jest --clearCache",
    "test:unit": "jest -c jest.config.json --detectOpenHandles --forceExit",
    "test:watch": "jest -c jest.config.json --watch --silent false",
    "test:coverage": "npm run test:unit -- --ci --coverage --runInBand",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bovidiu/node-file-caching.git"
  },
  "keywords": [
    "node",
    "caching",
    "node caching",
    "file caching",
    "node file caching",
    "npm cache",
    "npm caching",
    "npm file cache",
    "ttl",
    "namespace"
  ],
  "author": "Ovidiu Bokar",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bovidiu/node-file-caching/issues"
  },
  "homepage": "https://github.com/bovidiu/node-file-caching#readme",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@eslint/js": "^9.31.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "npm-run-all": "^4.1.5"
  }
}
